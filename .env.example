# .env.example (Copy this to .env)

# Strategy Name
STRAT_NAME=your_strategy_name_here

# Alpaca Paper Trading Credentials
ALPACA_API_KEY=your_testnet_api_key_here
ALPACA_API_SECRET=your_testnet_api_secret_here

# Discord Bot Webhook URL
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# PostgreSQL Database URL
DATABASE_URL=postgresql://your_db_user:your_db_password@your_db_host:your